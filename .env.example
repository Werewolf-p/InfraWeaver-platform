# ─────────────────────────────────────────────────────────────────────────────
# InfraWeaver Platform — Bootstrap Configuration
#
# USAGE:
#   cp .env.example .env
#   # Fill in the values below — everything else is auto-generated
#   bash scripts/bootstrap.sh
#
# PHILOSOPHY:
#   Only values that cannot be auto-generated belong here.
#   Auto-generated values (tokens, passwords, keys) are created during
#   bootstrap and stored in OpenBao — not in this file.
#   This file contains only:
#     - External service credentials (Proxmox, Cloudflare, SMTP)
#     - Infrastructure identifiers (domain, node IPs)
#     - SSH access to the Proxmox host
#
# SECURITY:
#   .env is in .gitignore — NEVER commit it.
#   Optional GitHub integration helpers live in:
#     .github/optional/scripts/
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# Base domain for all platform services. Used by cert-manager, Traefik,
# Authentik, Onedev, NetBird, etc.
# Example: yourdomain.com → services at *.yourdomain.com and *.int.yourdomain.com
BASE_DOMAIN=yourdomain.com
# Primary platform administrator email. Used for cert-manager ACME registration,
# Authentik bootstrap, console admin allowlist, and operational notifications.
ADMIN_EMAIL=admin@yourdomain.com

# ── Git Repository ────────────────────────────────────────────────────────────
# Repository slug used by the console/API when linking to workflows and files.
GITHUB_REPO=your-org/your-repo
# HTTPS repo URL without trailing .git. Used by Terraform + ArgoCD bootstrap.
GIT_REPO_URL=https://github.com/your-org/your-repo

# ── Proxmox ──────────────────────────────────────────────────────────────────
# API token for OpenTofu to provision VMs. Create in Proxmox UI:
#   Datacenter → Permissions → API Tokens → Add
# Format: USER@pve!TOKENNAME=<uuid>
PROXMOX_API_TOKEN=root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Cluster Topology ──────────────────────────────────────────────────────────
# Proxmox management IP or DNS name used by OpenTofu and deploy scripts.
PROXMOX_HOST=192.168.1.100
# Proxmox node name that will host the Talos VMs (single-node or clustered PVE).
PROXMOX_NODE_NAME=proxmox
# Kubernetes cluster name written into Talos and kubeconfig metadata.
K8S_CLUSTER_NAME=infraweaver-prod
# Default gateway for the node VLAN/subnet used by Talos control plane VMs.
NODE_GATEWAY=10.10.0.1
# CIDR prefix for the node subnet (for example: 24 = 255.255.255.0).
NODE_SUBNET_PREFIX=24
# Proxmox datastore name that stores Talos VM disks and Talos images.
TALOS_DATASTORE=lvm-proxmox
# Control plane node 1 IP and Proxmox VM ID. VM IDs must be unique cluster-wide.
NODE_1_IP=10.10.0.90
NODE_1_VMID=9310
# Control plane node 2 IP and Proxmox VM ID. VM IDs must be unique cluster-wide.
NODE_2_IP=10.10.0.91
NODE_2_VMID=9311
# Control plane node 3 IP and Proxmox VM ID. VM IDs must be unique cluster-wide.
NODE_3_IP=10.10.0.92
NODE_3_VMID=9312

# ── Per-node Proxmox placement & VM resources ─────────────────────────────────
# Maps each PVE node name to its SSH management IP (used by OpenTofu importdisk).
# Format: name1:ip1,name2:ip2  — covers all unique NODE_N_PVE_NODE values below.
# For single-node Proxmox this is derived automatically from PROXMOX_NODE_NAME + PROXMOX_HOST.
PVE_NODES=pve:192.168.1.100
# Which PVE node to deploy each K8s VM on. Defaults to PROXMOX_NODE_NAME if omitted.
NODE_1_PVE_NODE=pve
NODE_2_PVE_NODE=pve
NODE_3_PVE_NODE=pve
# Storage pool for each K8s VM disk. Defaults to TALOS_DATASTORE if omitted.
NODE_1_DATASTORE=lvm-proxmox
NODE_2_DATASTORE=lvm-proxmox
NODE_3_DATASTORE=lvm-proxmox
# VM resources per node. Defaults: cpu=4, memory=8192 MB, disk=100 GB.
NODE_1_CPU=4
NODE_1_MEMORY=8192
NODE_1_DISK=100
NODE_2_CPU=4
NODE_2_MEMORY=8192
NODE_2_DISK=100
NODE_3_CPU=4
NODE_3_MEMORY=8192
NODE_3_DISK=100

# ── MetalLB LoadBalancer VIPs ─────────────────────────────────────────────────
# These IPs are allocated from your node VLAN (NODE_GATEWAY subnet).
# They must be outside your DHCP range. Each service gets a dedicated VIP.
# The VIP range (all values 200-210) must be free on your VLAN.
# METALLB_VIP_RANGE defines the full pool; individual VIPs are assigned below.
# Example: if NODE_GATEWAY=10.10.0.1, use 10.10.0.200-10.10.0.210
METALLB_VIP_RANGE=10.10.0.200-10.10.0.210
METALLB_TRAEFIK_VIP=10.10.0.200        # Traefik ingress (all HTTP/S traffic)
METALLB_COREDNS_VIP=10.10.0.201        # Custom CoreDNS (resolves *.yourdomain.com internally)
METALLB_NETBIRD_MGMT_VIP=10.10.0.202   # NetBird management API (optional, only if ENABLE_NETBIRD=true)
METALLB_NETBIRD_SIGNAL_VIP=10.10.0.203 # NetBird signal server (optional)
METALLB_NETBIRD_RELAY_VIP=10.10.0.204  # NetBird relay server (optional)

# ── Platform Admin User ───────────────────────────────────────────────────────
# The first (admin) user of the platform. This username is used by:
#   - Authentik (login identity)
#   - ArgoCD RBAC (role:admin binding)
#   - NetBird (PAT token holder)
#   - OpenBao (password stored under this username)
# Keep it short and lowercase (no spaces). You can change it before first deploy.
ADMIN_USERNAME=admin
ADMIN_NAME=Platform Admin

# ── Cluster-local domain ──────────────────────────────────────────────────────
# Internal DNS zone used by Talos/CoreDNS for cluster-local name resolution.
# Default: prod.local — used by NetBird DNS routing and Talos node discovery.
# Only change this if prod.local conflicts with your existing LAN DNS.
CLUSTER_LOCAL_DOMAIN=prod.local

# ── SSH Key for Proxmox Access ────────────────────────────────────────────────
# Private SSH key used by deploy-local.sh to reach the Proxmox host.
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/infraweaver_proxmox -N ""
# Paste the full private key here (multi-line PEM).
DEPLOYER_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
# <paste private key here>
-----END OPENSSH PRIVATE KEY-----

# ── DNS Provider (cert-manager DNS-01) ────────────────────────────────────────
# DNS provider for cert-manager DNS-01 challenges (enables wildcard TLS certs).
# Options: cloudflare | route53 | azure | digitalocean | hetzner | none
# Use "none" to fall back to HTTP-01 (no wildcard certs — *.yourdomain.com will not work).
DNS_PROVIDER=cloudflare

# Cloudflare (DNS_PROVIDER=cloudflare)
# Create at: Cloudflare → My Profile → API Tokens → Edit Zone DNS template
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>

# AWS Route53 (DNS_PROVIDER=route53)
# IAM user needs: route53:ChangeResourceRecordSets, route53:GetChange, route53:ListHostedZonesByName
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_HOSTED_ZONE_ID=
AWS_REGION=us-east-1

# Azure DNS (DNS_PROVIDER=azure)
# Service principal needs: DNS Zone Contributor on the DNS zone resource
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=

# DigitalOcean (DNS_PROVIDER=digitalocean)
# Personal access token with write scope
DIGITALOCEAN_TOKEN=

# Hetzner DNS (DNS_PROVIDER=hetzner) — via cert-manager webhook
# Create API token at: https://dns.hetzner.com/settings/api-token
HETZNER_DNS_API_KEY=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# SMTP credentials for sending welcome emails and Alertmanager alerts.
# Using Outlook/Office365: host=smtp-mail.outlook.com port=587
# These cannot be auto-generated — they come from your email provider.
SMTP_USERNAME=your-email@outlook.com
SMTP_PASSWORD=your-app-password-here
SMTP_TO=your-alert-email@example.com

# ── NetBird ──────────────────────────────────────────────────────────────────
# API token for the NetBird management server. Used to clean up stale peers
# during full redeployments and to manage setup keys from CI.
# Generate in NetBird dashboard: Settings → API Keys
# NOTE: The management service token (NETBIRD_PAT) used by the cluster is
# auto-generated during bootstrap — only this external CI token is needed here.
NETBIRD_API_TOKEN=nbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional Features ────────────────────────────────────────────────────────
# These flags control which optional components are deployed.
# They are read by scripts/configure-platform.sh at deploy time and set the
# corresponding enabled/disabled state in platform.yaml.
#
# VPN — NetBird mesh VPN for secure remote access to cluster services.
#   true  → services behind *.int.yourdomain.com require VPN to access
#   false → services are accessible from homelab LAN only (internal-only middleware)
ENABLE_NETBIRD=false

# Monitoring — kube-prometheus-stack (Prometheus + Grafana + AlertManager).
#   true  → full metrics stack deployed, dashboard monitoring features enabled
#   false → no metrics stack (console degrades gracefully — metrics features hidden)
ENABLE_MONITORING=false

# External DNS — Cloudflare DNS sync (auto-creates DNS records for ingress hosts).
#   true  → requires DNS_PROVIDER=cloudflare and valid CLOUDFLARE_API_TOKEN; DNS entries auto-managed
#   false → manage DNS records manually in Cloudflare
ENABLE_EXTERNAL_DNS=false

# Backup provider — controls which backup systems are deployed.
#   none      → no automated backups
#   longhorn  → Longhorn block-level PVC backup to TrueNAS/NFS (recommended, lightweight)
#   velero    → Kubernetes-level backup (deployments, services, secrets + PVCs) to local MinIO
#   both      → both Longhorn and Velero (full protection)
#
# Note: Longhorn backup requires truenas NFS configured in platform.yaml
# Note: Velero requires more cluster resources (~1 CPU, ~2GB RAM for Velero + MinIO)
BACKUP_PROVIDER=longhorn

# ── Local Network Access (internal-only middleware) ───────────────────────────
# Comma-separated list of IP ranges (CIDR notation) that are allowed to access
# "internal" services — everything behind *.int.yourdomain.com that is NOT
# behind the VPN-only tier.
#
# This drives the Traefik "internal-only" middleware sourceRange.
# configure-platform.sh regenerates the middleware YAML from this value.
#
# Always-included automatically (not needed here):
#   - 10.244.0.0/16   K8s pod CIDR (health probes)
#   - 127.0.0.1/32    Localhost
#   - <node network>  K8s node VLAN (from cluster.yaml)
#   - 100.64.0.0/10   NetBird CGNAT (added automatically if ENABLE_NETBIRD=true)
#
# Examples:
#   Single subnet:      LOCAL_IP_RANGES=192.168.1.0/24
#   Multiple subnets:   LOCAL_IP_RANGES=192.168.1.0/24,10.0.0.0/24
#   Specific IP:        LOCAL_IP_RANGES=192.168.1.42/32
#   Mixed:              LOCAL_IP_RANGES=192.168.1.0/24,192.168.1.42/32,10.0.0.0/24
#
# Leave empty to allow VPN-only access (requires ENABLE_NETBIRD=true).
# If both are empty/false, internal services will be inaccessible — use with care.
LOCAL_IP_RANGES=192.168.1.0/24

# ── GitHub Integration (OPTIONAL) ────────────────────────────────────────────
# Only needed if you want to enable GitHub Actions integration.
# For standard local deployments, leave these blank.
GITHUB_PAT=
RUNNER_REGISTRATION_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Everything below is AUTO-GENERATED during bootstrap — do NOT set manually.
# Listing them here for documentation only.
#
# Auto-generated and stored in OpenBao:
#   - OPENBAO_ROOT_TOKEN      (generated on first init, stored in k8s Secret)
#   - ONEDEV_TOKEN            (created by scripts/setup-onedev.sh via Onedev API)
#   - ARGOCD_TOKEN            (generated by ArgoCD, stored in OpenBao)
#   - AUTHENTIK_BOOTSTRAP_TOKEN (generated by Authentik, stored in OpenBao)
#   - NEXTAUTH_SECRET         (random, generated by seed-catalog-secrets.sh)
#   - OIDC_CLIENT_SECRET      (random, one per app)
#   - GRAFANA_PASSWORD        (random, generated by bootstrap-openbao.sh)
#   - NETBIRD_PAT             (random, generated by bootstrap-openbao.sh)
#   - All app passwords       (random, generated by seed-catalog-secrets.sh)
#
# Cluster-specific values now live in this .env file and are substituted into
# envs/<env>/cluster.yaml and kubernetes/ templates by generate-from-env.sh.
# ─────────────────────────────────────────────────────────────────────────────
