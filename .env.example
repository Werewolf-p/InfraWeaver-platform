# ─────────────────────────────────────────────────────────────────────────────
# InfraWeaver Platform — Local Development Environment Template
#
# USAGE:
#   cp .env.example .env
#   # Fill in real values (see descriptions below)
#   # Then run: bash scripts/bootstrap-local.sh to validate your setup
#
# SECURITY:
#   .env is in .gitignore — NEVER commit it.
#   All values here flow into GitHub Secrets via:
#     bash scripts/push-secrets-to-github.sh
#
# GETTING EACH VALUE:
#   See CONTRIBUTING.md for full onboarding guide.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxmox ──────────────────────────────────────────────────────────────────
# Proxmox API token for OpenTofu to provision VMs.
# Create in Proxmox UI: Datacenter → Permissions → API Tokens
# Format: USER@pve!TOKENNAME=<secret>
PROXMOX_API_TOKEN=root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── SSH Key for GitHub Actions Runner VM ─────────────────────────────────────
# Private SSH key (RSA/Ed25519) used to SSH into the runner VM for provisioning.
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/infraweaver_runner -N ""
# Put the private key contents here (multi-line, base64 or raw PEM).
DEPLOYER_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----
# <paste private key here>
-----END OPENSSH PRIVATE KEY-----

# ── Cloudflare ───────────────────────────────────────────────────────────────
# Cloudflare API token for cert-manager DNS-01 challenges and DNS record management.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit for your zone (rlservers.com or equivalent).
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>

# ── Age / SOPS Encryption ────────────────────────────────────────────────────
# Age private key for decrypting SOPS secrets in envs/*/secrets.sops.yaml.
# Generate: age-keygen -o ~/.config/sops/age/keys.txt
# The key starts with "AGE-SECRET-KEY-..."
AGE_SECRET_KEY=AGE-SECRET-KEY-1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OpenBao (Vault) ──────────────────────────────────────────────────────────
# Root token for OpenBao. Generated during cluster bootstrap (full-redeploy).
# Find in full-redeploy workflow output or in your notes from initial setup.
# WARNING: rotate this after initial setup with:
#   kubectl exec -n openbao openbao-0 -- bao auth enable approle
OPENBAO_ROOT_TOKEN=hvs.XXXXXXXXXXXXXXXXXXXXXXXX

# ── ArgoCD GitHub Integration ─────────────────────────────────────────────────
# GitHub Personal Access Token (PAT) used by ArgoCD to pull from private repos.
# Create at: https://github.com/settings/tokens → "repo" scope minimum.
# Ideally: use a GitHub App installation token instead (rotate hourly).
ARGOCD_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NetBird API ──────────────────────────────────────────────────────────────
# NetBird management API token for setup key rotation and peer management.
# Generate in NetBird dashboard: Settings → API Keys
NETBIRD_API_TOKEN=nbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub Actions Runner ─────────────────────────────────────────────────────
# GitHub Actions runner registration token for the self-hosted prod-worker runner.
# Find at: https://github.com/<org>/<repo>/settings/actions/runners/new
# NOTE: These tokens expire after 1 hour — regenerate before each new runner setup.
RUNNER_REGISTRATION_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# SMTP credentials for sending welcome emails and Alertmanager alerts.
# Using Outlook/Office365: smtp-mail.outlook.com:587 with TLS
SMTP_USERNAME=your-email@outlook.com
SMTP_PASSWORD=your-app-password-here
# Destination for platform alerts (Alertmanager)
SMTP_TO=your-alert-email@example.com
