# Dockerfile.prebuilt — uses pre-built dist/ (tsc runs on the CI host, not inside Alpine)
# Usage: npm run build && buildah build -f Dockerfile.prebuilt --build-arg APP_VERSION=<tag>
FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
ARG APP_VERSION=dev
ENV APP_VERSION=$APP_VERSION
COPY package*.json ./
RUN npm ci --omit=dev
COPY dist/ ./dist/
USER node
EXPOSE 3001
CMD ["node", "dist/index.js"]
