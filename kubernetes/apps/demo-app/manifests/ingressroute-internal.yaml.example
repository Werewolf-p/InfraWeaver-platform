---
# INTERNAL IngressRoute — only accessible via NetBird VPN
#
# Rename this file from .yaml.example → .yaml to activate it.
# URL: https://demo-app.int.rlservers.com  (only reachable when connected to NetBird)
#
# The `netbird-vpn-only` middleware allows only VPN traffic through.
# No Authentik login required — the VPN itself is the authentication layer.
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: demo-app-internal
  namespace: apps-demo-app
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`demo-app.int.rlservers.com`)
      kind: Rule
      middlewares:
        - name: netbird-vpn-only
          namespace: traefik
      services:
        - name: demo-app
          port: 80
  tls:
    secretName: demo-app-int-tls
---
# Certificate for demo-app.int.rlservers.com
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: demo-app-int-tls
  namespace: apps-demo-app
spec:
  secretName: demo-app-int-tls
  issuerRef:
    name: letsencrypt-dns
    kind: ClusterIssuer
  dnsNames:
    - demo-app.int.rlservers.com
