---
# PUBLIC IngressRoute — accessible from the internet
#
# Rename this file from .yaml.example → .yaml to activate it.
# URL: https://demo-app.rlservers.com  (⚠️ world-reachable!)
#
# ⚠️  Think twice before enabling this.
#    Only enable for apps that are explicitly designed to be public.
#    Consider adding `forward-auth` middleware for Authentik SSO protection:
#      middlewares:
#        - name: forward-auth
#          namespace: traefik
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: demo-app-public
  namespace: apps-demo-app
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`demo-app.rlservers.com`)
      kind: Rule
      # Optional: add Authentik SSO protection:
      # middlewares:
      #   - name: forward-auth
      #     namespace: traefik
      services:
        - name: demo-app
          port: 80
  tls:
    secretName: demo-app-tls
---
# Certificate for demo-app.rlservers.com
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: demo-app-tls
  namespace: apps-demo-app
spec:
  secretName: demo-app-tls
  issuerRef:
    name: letsencrypt-dns
    kind: ClusterIssuer
  dnsNames:
    - demo-app.rlservers.com
